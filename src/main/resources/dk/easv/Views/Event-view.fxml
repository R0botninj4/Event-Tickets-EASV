<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="475.0" prefWidth="525.0"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.event_tickets_easv_bar.GUI.EventController">

    <top>
        <VBox prefWidth="629.0">
            <children>
                <HBox prefHeight="53.0" prefWidth="753.0">
                    <children>
                        <Label prefHeight="67.0" prefWidth="172.0" text="Event view">
                            <font>
                                <Font name="System Bold" size="15.0"/>
                            </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblUserRole" prefHeight="33.0" prefWidth="121.0">
                            <HBox.margin>
                                <Insets bottom="10.0" top="10.0"/>
                            </HBox.margin>
                        </Label>
                        <Button fx:id="closeButton" mnemonicParsing="false" onAction="#Close"
                                prefHeight="37.0" prefWidth="121.0" text="Close">
                            <HBox.margin>
                                <Insets bottom="10.0" top="10.0"/>
                            </HBox.margin>
                        </Button>
                    </children>
                </HBox>
            </children>
            <padding>
                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
            </padding>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;"
                    BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="10.0" left="10.0" right="10.0"/>
            </BorderPane.margin>

            <GridPane hgap="20" vgap="14">
                <padding>
                    <Insets bottom="15.0" left="20.0" right="20.0" top="10.0"/>
                </padding>

                <columnConstraints>
                    <ColumnConstraints minWidth="150" prefWidth="160"/>
                    <ColumnConstraints minWidth="200" prefWidth="280"/>
                </columnConstraints>

                <!-- Event name -->
                <Label text="Event name" style="-fx-text-fill: black;"
                       GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="lblEventName" style="-fx-text-fill: black;"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <!-- Coordinator -->
                <Label text="Coordinator" style="-fx-text-fill: black;"
                       GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="lblCoordinator" style="-fx-text-fill: black;"
                       GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Event info -->
                <Label text="Event info" style="-fx-text-fill: black;"
                       GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="lblEventInfo" style="-fx-text-fill: black;" wrapText="true"
                       GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <!-- Event date -->
                <Label text="Event date" style="-fx-text-fill: black;"
                       GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="lblEventDate" style="-fx-text-fill: black;"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <!-- End date -->
                <Label text="End date" style="-fx-text-fill: black;"
                       GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="lblEndDate" style="-fx-text-fill: black;"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <!-- End time -->
                <Label text="End time" style="-fx-text-fill: black;"
                       GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <Label fx:id="lblEndTime" style="-fx-text-fill: black;"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <!-- Ticket amount -->
                <Label text="Ticket amount" style="-fx-text-fill: black;"
                       GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <Label fx:id="lblTicketAmount" style="-fx-text-fill: black;"
                       GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <!-- Tickets sold -->
                <Label text="Tickets sold" style="-fx-text-fill: black;"
                       GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <Label fx:id="lblTicketsSold" style="-fx-text-fill: black;"
                       GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <!-- Tickets left -->
                <Label text="Tickets left" style="-fx-text-fill: black;"
                       GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <Label fx:id="lblTicketsLeft" style="-fx-text-fill: black;"
                       GridPane.rowIndex="8" GridPane.columnIndex="1"/>

                <!-- Location -->
                <Label text="Location" style="-fx-text-fill: black;"
                       GridPane.rowIndex="9" GridPane.columnIndex="0"/>
                <Label fx:id="lblLocation" style="-fx-text-fill: black;"
                       GridPane.rowIndex="9" GridPane.columnIndex="1"/>

                <!-- Location guidance -->
                <Label text="Location guidance" style="-fx-text-fill: black;"
                       GridPane.rowIndex="10" GridPane.columnIndex="0"/>
                <Label fx:id="lblLocationGuidance" style="-fx-text-fill: black;" wrapText="true"
                       GridPane.rowIndex="10" GridPane.columnIndex="1"/>

            </GridPane>
        </ScrollPane>
    </center>

</BorderPane>