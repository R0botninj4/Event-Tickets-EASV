<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/24.0.1"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.event_tickets_easv_bar.GUI.PrintTicketsController">

    <center>
        <TableView fx:id="ticketTable">
            <columns>
                <TableColumn fx:id="colEvent" text="Event"/>
                <TableColumn fx:id="colType" text="Type"/>
                <TableColumn fx:id="colAmount" text="Amount"/>
                <TableColumn fx:id="colEmail" text="Email"/>
                <TableColumn fx:id="colDate" text="Purchase Date"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10;">
            <Button text="Print Selected" onAction="#handlePrintSelected"/>
            <Button text="Close" onAction="#handleClose"/>
        </HBox>
    </bottom>

</BorderPane>