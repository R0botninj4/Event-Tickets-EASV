<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane prefHeight="488.0" prefWidth="533.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.event_tickets_easv_bar.GUI.PrintTicketsController">
   <center>
      <VBox prefHeight="200.0" prefWidth="100.0" BorderPane.alignment="CENTER">
         <children>
            <HBox prefHeight="39.0" prefWidth="533.0" spacing="20.0" styleClass="cBoarder" stylesheets="@counter-strike-source.css">
               <children>
                  <TextField fx:id="txtSearch" promptText="Search event">
                     <HBox.margin>
                        <Insets left="10.0" />
                     </HBox.margin>
                  </TextField>
                  <Separator orientation="VERTICAL" prefHeight="25.0" prefWidth="62.0" />

                     <Button onAction="#handlePrintSelected" text="Print" HBox.hgrow="ALWAYS" >
                         <graphic>
                             <ImageView fitHeight="20" fitWidth="20" preserveRatio="true">
                                 <image>
                                     <Image url="@../../../Icons/icon_print.png" />
                                 </image>
                             </ImageView>
                         </graphic>
                     </Button>

                  <Separator orientation="VERTICAL" prefHeight="25.0" prefWidth="62.0" />
                     <Button onAction="#handleClose" text="Close" HBox.hgrow="ALWAYS" />
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
               <padding>
                  <Insets bottom="10.0" top="10.0" />
               </padding>
            </HBox>
              <TableView fx:id="ticketTable" styleClass="cBoarder" stylesheets="@counter-strike-source.css" VBox.vgrow="ALWAYS">
                  <columns>
                      <TableColumn fx:id="colEvent" text="Event" />
                      <TableColumn fx:id="colType" text="Type" />
                      <TableColumn fx:id="colAmount" text="Amount" />
                      <TableColumn fx:id="colEmail" text="Email" />
                      <TableColumn fx:id="colDate" text="Purchase Date" />
                  </columns>
               <columnResizePolicy>
                  <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
               </columnResizePolicy>
              </TableView>
         </children>
         <BorderPane.margin>
            <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
         </BorderPane.margin>
      </VBox>
   </center>

</BorderPane>
