<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane stylesheets="@counter-strike-source.css" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.event_tickets_easv_bar.GUI.HelloController">
   <top>
      <VBox spacing="10">
         <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
         </padding>
         <children>
            <HBox prefHeight="53.0" prefWidth="753.0">
               <children>
                  <Label prefHeight="67.0" prefWidth="172.0" text="Events">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Label>
                  <Region prefHeight="53.0" prefWidth="711.0" HBox.hgrow="ALWAYS" />
                  <Label prefHeight="33.0" prefWidth="84.0" text="Coordinator">
                     <HBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                     </HBox.margin>
                  </Label>
                  <Button alignment="CENTER" mnemonicParsing="false" prefHeight="37.0" prefWidth="121.0" text="Close">
                     <HBox.margin>
                        <Insets bottom="10.0" top="10.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   <right>
      <VBox prefHeight="507.0" prefWidth="300" spacing="10" styleClass="cBoarder">
         <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
         </padding>
         <children>
            <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Event creation" />
            <TextField promptText="Event Name" />
            <TextField promptText="Date" />
            <TextField promptText="Location" />
            <TextField promptText="Coordinator" />
            <TextField promptText="Ticket amount" />
            <TextField promptText="Info" />
            <Separator />
            <Button maxWidth="Infinity" text="Add Event" />
            <Separator prefHeight="49.0" prefWidth="280.0" />
            <Label alignment="CENTER" prefHeight="17.0" prefWidth="287.0" text="Selected Event" />
            <Button maxWidth="Infinity" text="Edit Event" />
            <Button maxWidth="Infinity" text="Update Event" />
         </children>
         <BorderPane.margin>
            <Insets bottom="10.0" right="10.0" />
         </BorderPane.margin>
      </VBox>
   </right>
   <center>
      <TableView prefHeight="499.0" prefWidth="809.0" styleClass="cBoarder" BorderPane.alignment="CENTER">
         <columns>
            <TableColumn prefWidth="97.3333740234375" text="Event name" />
            <TableColumn prefWidth="76.66668701171875" text="Date" />
            <TableColumn prefWidth="82.0" text="Location" />
            <TableColumn prefWidth="81.33331298828125" text="Coordiantor" />
            <TableColumn prefWidth="131.33334350585938" text="Status/Tickets left" />
            <TableColumn prefWidth="123.33331298828125" text="Tickets sold" />
            <TableColumn minWidth="7.99993896484375" prefWidth="110.6666259765625" text="Event info" />
         </columns>
         <BorderPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" />
         </BorderPane.margin>
         <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
         </columnResizePolicy>
      </TableView>
   </center>
</BorderPane>
