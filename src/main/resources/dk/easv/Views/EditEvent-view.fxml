<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="520.0" prefWidth="500.0"
      stylesheets="@counter-strike-source.css"
      xmlns="http://javafx.com/javafx/24.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.event_tickets_easv_bar.GUI.EditEventController">

    <children>

        <!-- Top bar -->
        <HBox prefHeight="53.0" prefWidth="500.0">
            <children>
                <Label prefHeight="67.0" prefWidth="172.0" text="Edit Event">
                    <font><Font name="System Bold" size="15.0"/></font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="closeButton" mnemonicParsing="false" onAction="#handleClose"
                        prefHeight="37.0" prefWidth="100.0" text="Close">
                    <HBox.margin><Insets bottom="10.0" right="10.0" top="10.0"/></HBox.margin>
                </Button>
            </children>
            <VBox.margin><Insets left="10.0"/></VBox.margin>
        </HBox>

        <!-- Form -->
        <GridPane hgap="15" vgap="12" styleClass="cBoarder">
            <padding><Insets bottom="15.0" left="20.0" right="20.0" top="15.0"/></padding>
            <VBox.margin><Insets bottom="10.0" left="10.0" right="10.0"/></VBox.margin>

            <columnConstraints>
                <ColumnConstraints minWidth="140" prefWidth="150"/>
                <ColumnConstraints minWidth="200" prefWidth="280" hgrow="ALWAYS"/>
            </columnConstraints>

            <!-- Event name -->
            <Label text="Event name" style="-fx-text-fill: black;"
                   GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEventName" style="-fx-text-fill: black;"
                       GridPane.rowIndex="0" GridPane.columnIndex="1"/>

            <!-- Event info -->
            <Label text="Event info" style="-fx-text-fill: black;"
                   GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextArea fx:id="txtEventInfo" style="-fx-text-fill: black;"
                      prefHeight="60" wrapText="true"
                      GridPane.rowIndex="1" GridPane.columnIndex="1"/>

            <!-- Event date -->
            <Label text="Event date" style="-fx-text-fill: black;"
                   GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpEventDate"
                        GridPane.rowIndex="2" GridPane.columnIndex="1"/>

            <!-- End date -->
            <Label text="End date" style="-fx-text-fill: black;"
                   GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <DatePicker fx:id="dpEndDate"
                        GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            <!-- End time -->
            <Label text="End time (HH:mm)" style="-fx-text-fill: black;"
                   GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <TextField fx:id="txtEndTime" promptText="e.g. 21:00" style="-fx-text-fill: black;"
                       GridPane.rowIndex="4" GridPane.columnIndex="1"/>

            <!-- Location -->
            <Label text="Location" style="-fx-text-fill: black;"
                   GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <TextField fx:id="txtLocation" style="-fx-text-fill: black;"
                       GridPane.rowIndex="5" GridPane.columnIndex="1"/>

            <!-- Location guidance -->
            <Label text="Location guidance" style="-fx-text-fill: black;"
                   GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <TextField fx:id="txtLocationGuidance" style="-fx-text-fill: black;"
                       GridPane.rowIndex="6" GridPane.columnIndex="1"/>

            <!-- Ticket amount -->
            <Label text="Ticket amount" style="-fx-text-fill: black;"
                   GridPane.rowIndex="7" GridPane.columnIndex="0"/>
            <Spinner fx:id="spTicketAmount" min="0" max="99999" initialValue="0"
                     editable="true" style="-fx-text-fill: black;"
                     GridPane.rowIndex="7" GridPane.columnIndex="1"/>

            <!-- Coordinator -->
            <Label text="Coordinator" style="-fx-text-fill: black;"
                   GridPane.rowIndex="8" GridPane.columnIndex="0"/>
            <ComboBox fx:id="cmbCoordinator" prefWidth="280"
                      GridPane.rowIndex="8" GridPane.columnIndex="1"/>

        </GridPane>

        <!-- Save button -->
        <HBox alignment="CENTER_RIGHT">
            <VBox.margin><Insets right="10.0" top="10.0"/></VBox.margin>
            <Button fx:id="btnSave" mnemonicParsing="false" onAction="#handleSave"
                    prefHeight="36.0" prefWidth="100.0" text="Save"/>
        </HBox>

    </children>
</VBox>